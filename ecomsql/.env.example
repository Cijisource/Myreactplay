# Database Configuration
DB_SERVER=gnanabi.database.windows.net
DB_NAME=mansion
DB_USER=servergnanaabi
DB_PASSWORD=serverpassword@123
DB_PORT=1433

# Server Configuration
PORT=5000
NODE_ENV=production
CLIENT_URL=http://localhost:3000

# JWT Configuration - Must be set for token generation and verification
JWT_SECRET=your-secret-key-here

# Client Configuration
# API URL for React frontend
# With nginx (default): http://localhost/api (single entry point on port 80)
# Without nginx: http://localhost:5000/api (direct backend access)
# For Docker service names: http://server:5000/api
REACT_APP_API_URL=http://localhost/api
