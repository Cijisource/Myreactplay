# NPM configuration for optimized installation
# This file is used automatically when running npm install

# Accept peer dependency mismatches without blocking
legacy-peer-deps=true

# Prefer offline mode for faster installs
prefer-offline=true

# Skip audit security check (speeds up install)
no-audit=true

# Configure timeouts for slow networks
fetch-timeout=60000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Dependency depth (0 = all transitive dependencies)
depth=0

# Use modern npm dependency resolution strategy (replaces deprecated legacy-bundling)
install-strategy=nested

# Suppress engine mismatch warnings for cached packages
engine-strict=false

# Suppress deprecation warnings during installation
# (packages will still work, just with outdated features)
# Note: Critical security vulnerabilities should still be addressed

