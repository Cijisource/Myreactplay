DB_SERVER=gnanabi.database.windows.net
DB_PORT=1433
DB_DATABASE=mansion
DB_USER=servergnanaabi
DB_PASSWORD=serverpassword@123
EXPRESS_PORT=5000
NODE_ENV=development

# Azure Blob Storage (optional - only needed for SDK-based uploads)
# Photo fallback uses URL-based downloads and works without a connection string
# To get a real connection string: https://docs.microsoft.com/azure/storage/common/storage-account-keys-manage
# Format: DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONNECTION_STRING=your_connection_string
AZURE_CONTAINER_NAME=proofs
AZURE_BLOB_URL=https://complexstore.blob.core.windows.net/proofs
