# Azure Storage Configuration
# Option 1: Using connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccountname;AccountKey=youraccountkey;EndpointSuffix=core.windows.net

# Option 2: Using account credentials
AZURE_STORAGE_ACCOUNT_NAME=youraccountname
AZURE_STORAGE_ACCOUNT_KEY=youraccountkey

# Container name (default: "uploads")
AZURE_STORAGE_CONTAINER=uploads

# Folder(s) to upload - comma-separated for multiple folders (default: current directory)
# Single folder: ./photos
# Multiple folders: ./photos,./videos,./documents
UPLOAD_FOLDER=./photos
